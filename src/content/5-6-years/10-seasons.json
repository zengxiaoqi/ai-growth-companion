{
  "id": "science_101",
  "name": "四季变化",
  "ageRange": "5-6",
  "domain": "science",
  "duration": 10,
  "difficulty": 1,
  "objectives": [
    "认识春、夏、秋、冬四个季节",
    "了解每个季节的特点",
    "观察身边季节变化的现象"
  ],
  "content": [
    {
      "type": "lesson",
      "title": "春夏秋冬",
      "text": "一年有四个季节：春天、夏天、秋天、冬天。\n\n🌸 春天：天气暖和了，花儿开了，小草绿了，小鸟飞回来了。\n\n☀️ 夏天：天气很热，可以吃冰淇淋、游泳，晚上有萤火虫。\n\n🍂 秋天：天气变凉了，树叶变黄了，果实成熟了，农民伯伯收获了。\n\n❄️ 冬天：天气很冷，会下雪，小动物们开始冬眠了。",
      "examples": [
        {"春天": "花开、草绿、燕子回来"},
        {"夏天": "热、游泳、吃冰淇淋"},
        {"秋天": "落叶、果实成熟、天气凉爽"},
        {"冬天": "下雪、寒冷、动物冬眠"}
      ]
    },
    {
      "type": "game",
      "title": "季节配对",
      "description": "选择正确的季节",
      "questions": [
        {"q": "树叶变黄了，是什么季节？", "options": ["春天", "夏天", "秋天", "冬天"], "answer": "秋天"},
        {"q": "可以游泳的季节是？", "options": ["春天", "夏天", "秋天", "冬天"], "answer": "夏天"},
        {"q": "下雪了，是什么季节？", "options": ["春天", "夏天", "秋天", "冬天"], "answer": "冬天"},
        {"q": "花儿开了，是什么季节？", "options": ["春天", "夏天", "秋天", "冬天"], "answer": "春天"},
        {"q": "果实成熟的季节是？", "options": ["春天", "夏天", "秋天", "冬天"], "answer": "秋天"}
      ]
    },
    {
      "type": "practice",
      "title": "季节观察",
      "description": "说说你现在是什么季节，有什么特点",
      "prompts": [
        "现在是什么季节？",
        "这个季节有什么特点？",
        "这个季节我们可以做什么？"
      ]
    }
  ],
