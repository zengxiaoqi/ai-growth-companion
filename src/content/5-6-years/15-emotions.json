{
  "id": "social_101",
  "name": "认识情绪",
  "ageRange": "5-6",
  "domain": "social",
  "duration": 10,
  "difficulty": 1,
  "objectives": [
    "认识基本情绪：开心、难过、生气、害怕",
    "学会表达和识别情绪",
    "掌握情绪调节的基本方法"
  ],
  "content": [
    {
      "type": "lesson",
      "title": "我的情绪小怪兽",
      "text": "每个人都会有不同的情绪：\n\n😊 开心：嘴角向上翘，眼睛眯起来，心裡美美的。\n\n😢 难过：想哭，眼淚掉下來，心裡不舒服。\n\n😠 生气：眉头皱起来，嘴巴嘟起来，想大声说话。\n\n😨 害怕：心跳加快，想躲起来，不敢看。\n\n情绪就像小怪兽，我们要学会认识它们！",
      "examples": [
        {
          "开心": "得到礼物、玩游戏、吃好吃的"
        },
        {
          "难过": "摔倒了、玩具坏了、和朋友分开"
        },
        {
          "生气": "东西被抢、被人欺负、完不成任务"
        },
        {
          "害怕": "一个人在家、看到可怕的东西"
        }
      ]
    },
    {
      "type": "game",
      "title": "情绪猜猜看",
      "description": "看看表情，猜是什么情绪",
      "questions": [
        {
          "q": "小明的嘴角向上翘，他在？",
          "options": [
            "开心",
            "难过",
            "生气"
          ],
          "answer": "开心"
        },
        {
          "q": "小华哭了，他在？",
          "options": [
            "开心",
            "难过",
            "害怕"
          ],
          "answer": "难过"
        },
        {
          "q": "小强眉头皱起来，他在？",
          "options": [
            "开心",
            "生气",
            "害怕"
          ],
          "answer": "生气"
        },
        {
          "q": "小美躲起来了，她在？",
          "options": [
            "开心",
            "难过",
            "害怕"
          ],
          "answer": "害怕"
        }
      ]
    },
    {
      "type": "practice",
      "title": "情绪表达",
      "description": "说出今天的情绪",
      "prompts": [
        "今天你感觉怎么样？",
        "什么事情让你开心？",
        "如果你生气了，怎么做会好一些？"
      ]
    }
  ],
