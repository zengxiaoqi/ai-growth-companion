# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置 (SQLite)
DB_PATH=lingxi.db

# JWT 配置
JWT_SECRET=lingxi-secret-key-change-in-production

# Redis 配置 (可选)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# AI / LLM 配置 (OpenAI 兼容接口)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7