  "content": [
    {
      "type": "lesson",
      "title": "加法的秘密",
      "text": "什么是加法？\n\n加法就是，把东西合并在一起，数一数一共有多少。\n\n比如：\n🍎 + 🍎 = 2个苹果\n1 + 1 = 2\n\n🔢 + 🔢 = 4个圆\n2 + 2 = 4\n\n我们来学习10以内的加法吧！",
      "examples": [
        {"1+1": 2, "visual": "🍎+🍎=🍎🍎"},
        {"1+2": 3, "visual": "🍎+🍎🍎=🍎🍎🍎"},
        {"2+2": 4, "visual": "🍎🍎+🍎🍎=🍎🍎🍎🍎"},
        {"2+3": 5, "visual": "🍎🍎+🍎🍎🍎=🍎🍎🍎🍎🍎"},
        {"3+3": 6, "visual": "🍎🍎🍎+🍎🍎🍎=🍎🍎🍎🍎🍎🍎"}
      ]
    },
    {
      "type": "game",
      "title": "加法运算",
      "description": "选择正确的答案",
      "questions": [
        {"q": "1 + 2 = ?", "options": [1, 2, 3], "answer": 2},
        {"q": "2 + 3 = ?", "options": [4, 5, 6], "answer": 1},
        {"q": "3 + 2 = ?", "options": [4, 5, 6], "answer": 1},
        {"q": "4 + 3 = ?", "options": [6, 7, 8], "answer": 1},
        {"q": "5 + 4 = ?", "options": [8, 9, 10], "answer": 1}
      ]
    },
