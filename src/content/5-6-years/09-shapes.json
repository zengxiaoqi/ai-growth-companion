{
  "id": "math_103",
  "name": "认识图形",
  "ageRange": "5-6",
  "domain": "math",
  "duration": 12,
  "difficulty": 2,
  "objectives": [
    "认识圆形、三角形、正方形、长方形",
    "能够区分不同形状的物品",
    "培养观察和分类能力"
  ],
  "content": [
    {
      "type": "lesson",
      "title": "图形朋友",
      "text": "我们身边有很多形状朋友，让我来介绍一下：\n\n⭕ 圆形：像球一样，没有角\n三角形：有3个角，3条边\n正方形：4个角一样大，4条边一样长\n长方形：像长长的大盒子，4个角，4条边\n\n找找看，你身边有哪些形状？",
      "examples": [
        {"圆形": "球、苹果、钟表", "三角形": "红领巾、屋顶、旗帜"},
        {"正方形": "手帕、瓷砖、盒子", "长方形": "门、窗户、手机"}
      ]
    },
    {
      "type": "game",
      "title": "找图形",
      "description": "找出图片中的形状",
      "questions": [
        {"q": "这个是什么形状？", "image": "circle.png", "options": ["圆形", "三角形", "正方形"], "answer": "圆形"},
        {"q": "这个是什么形状？", "image": "triangle.png", "options": ["圆形", "三角形", "正方形"], "answer": "三角形"},
        {"q": "这个是什么形状？", "image": "square.png", "options": ["圆形", "正方形", "长方形"], "answer": "正方形"},
        {"q": "这个是什么形状？", "image": "rectangle.png", "options": ["正方形", "长方形", "三角形"], "answer": "长方形"},
        {"q": "红领巾是什么形状？", "options": ["圆形", "三角形", "正方形"], "answer": "三角形"}
      ]
    },
    {
      "type": "practice",
      "title": "形状配对",
      "description": "把物品和对应的形状连起来",
      "items": [
        {"物品": "足球", "形状": "圆形"},
        {"物品": "三明治", "形状": "三角形"},
        {"物品": "靠垫", "形状": "正方形"},
        {"物品": "数学本", "形状": "长方形"}
      ]
    }
  ],
  "media": {
    "images": ["/assets/images/math/shapes.png"]
  },
  "abilities": {
    "observation": 20,
    "logic": 10
  }
}