# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置 (SQLite)
DB_PATH=lingxi.db

# JWT 配置
JWT_SECRET=lingxi-secret-key-change-in-production

# Redis 配置 (可选)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# AI / LLM 配置 (OpenAI 兼容接口)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# 阿里云短信/语音配置 (紧急呼叫功能)
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIBABA_CLOUD_SMS_SIGN_NAME=灵犀伴学
ALIBABA_CLOUD_SMS_TEMPLATE_CODE=
ALIBABA_CLOUD_VOICE_TTS_CODE=
# Teaching video third-party generation (async queue)
# VIDEO_PROVIDER_MODE: hybrid | local_only | off
VIDEO_PROVIDER_MODE=hybrid
VIDEO_PROVIDER_NAME=vibemotion
VIDEO_PROVIDER_BASE_URL=
VIDEO_PROVIDER_API_KEY=
VIDEO_PROVIDER_CREATE_PATH=/v1/video/tasks
VIDEO_PROVIDER_STATUS_PATH=/v1/video/tasks/{taskId}
VIDEO_PROVIDER_REQUEST_TIMEOUT_MS=20000
VIDEO_PROVIDER_EXTRA_HEADERS_JSON=
VIDEO_PROVIDER_CREATE_BODY_MODE=generic
VIDEO_PROVIDER_CREATE_INPUT_KEY=input
VIDEO_PROVIDER_CREATE_VIDEO_URL_PATHS=videoUrl,url,data.videoUrl,result.videoUrl
VIDEO_PROVIDER_CREATE_TASK_ID_PATHS=taskId,jobId,id,data.taskId,data.id
VIDEO_PROVIDER_STATUS_STATE_PATHS=status,state,data.status,result.status
VIDEO_PROVIDER_STATUS_PROGRESS_PATHS=progress,percent,data.progress,result.progress
VIDEO_PROVIDER_STATUS_ERROR_PATHS=error,message,data.error,result.error
VIDEO_PROVIDER_STATUS_VIDEO_URL_PATHS=videoUrl,url,downloadUrl,data.videoUrl,data.url,result.videoUrl,result.url
VIDEO_PROVIDER_DOWNLOAD_TIMEOUT_MS=45000
VIDEO_PROVIDER_DOWNLOAD_MAX_MB=80
VIDEO_PROVIDER_DOWNLOAD_HOST_ALLOWLIST=
VIDEO_PROVIDER_ALLOW_HTTP_DOWNLOAD=false
VIDEO_PROVIDER_ALLOW_PRIVATE_DOWNLOAD_HOSTS=false

# Queue/cache settings
VIDEO_TASK_POLL_INTERVAL_MS=3000

# 外部技能目录 (可选)
# SKILLS_DIR=/path/to/external/skills
VIDEO_PROVIDER_POLL_MS=2500
VIDEO_PROVIDER_POLL_MAX_TIMES=120
VIDEO_TASK_MAX_RETRIES=2
VIDEO_CACHE_TTL_HOURS=72
