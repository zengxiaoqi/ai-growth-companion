{
  "id": "story-generation",
  "name": "故事生成",
  "description": "生成适合年龄的教育故事",
  "triggers": ["故事", "讲故事", "听故事", "story"],
  "promptTemplate": "为{{ageGroup}}岁的孩子创作一个关于{{topic}}的教育故事。故事应该有趣、有教育意义，包含{{characterCount}}个角色。长度约{{wordCount}}字。",
  "variables": [
    { "name": "topic", "type": "string", "required": true, "description": "故事主题" },
    { "name": "characterCount", "type": "number", "required": false, "defaultValue": 2, "description": "角色数量" },
    { "name": "wordCount", "type": "number", "required": false, "defaultValue": 200, "description": "字数" },
    { "name": "ageGroup", "type": "string", "required": true, "description": "年龄组" }
  ],
  "requiredTools": [],
  "ageGroups": ["3-4", "5-6"]
}
