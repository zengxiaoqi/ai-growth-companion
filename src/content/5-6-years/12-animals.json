  "content": [
    {
      "type": "lesson",
      "title": "动物朋友",
      "text": "动物是我们的好朋友，让我们来认识它们：\n\n🐱 小猫：会抓老鼠，喵喵叫，喜欢吃鱼。\n\n🐶 小狗：是人类最好的朋友，会看家，汪汪叫。\n\n🐰 小兔子：跳跳跳，爱吃胡萝卜，耳朵长长的。\n\n🐦 小鸟：会飞，会唱歌，住在大树上。\n\n🐟 小鱼：生活在水里，会游泳，用鳃呼吸。",
      "examples": [
        {
          "🐱 小猫": "哺乳动物，吃鱼，会抓老鼠"
        },
        {
          "🐶 小狗": "哺乳动物，看家，吃骨头"
        },
        {
          "🐰 兔子": "哺乳动物，跳着走，吃胡萝卜"
        },
        {
          "🐦 鸟类": "会飞，吃虫子，住树上"
        }
      ]
    },
    {
      "type": "game",
      "title": "动物找家",
      "description": "动物住在哪里？",
      "questions": [
        {
          "q": "小鱼住在哪里？",
          "options": [
            "水里",
            "树上",
            "地上"
          ],
          "answer": "水里"
        },
        {
          "q": "小鸟住在哪里？",
          "options": [
            "水里",
            "树上",
            "地下"
          ],
          "answer": "树上"
        },
        {
          "q": "兔子吃什么？",
          "options": [
            "鱼",
            "胡萝卜",
            "肉"
          ],
          "answer": "胡萝卜"
        },
        {
          "q": "谁会飞？",
          "options": [
            "小猫",
            "小狗",
            "小鸟"
          ],
          "answer": "小鸟"
        },
        {
          "q": "谁会抓老鼠？",
          "options": [
            "小狗",
            "小猫",
            "兔子"
          ],
          "answer": "小猫"
        }
      ]
    },
    {
      "type": "practice",
      "title": "动物分类",
      "description": "说说你认识哪些动物",
      "categories": [
        "会飞的动物：",
        "会游泳的动物：",
        "会跳的动物："
      ]
    }
  ],
