        },
        {
          "char": "月",
          "meaning": "月亮",
          "strokes": 4,
          "words": ["月亮", "一月", "月光"],
          "story": "月亮弯弯的，像小船，两边有短短的竖，就像月亮的边。"
        },
        {
          "char": "水",
          "meaning": "水",
          "strokes": 4,
          "words": ["水果", "喝水", "清水"],
          "story": "水可以流动，中间有一撇一捺，就像水流的样子。"
        },
        {
          "char": "火",
          "meaning": "火",
          "strokes": 4,
          "words": ["火车", "大火", "点火"],
          "story": "火苗往上冒，上面是两点，下面是人字形。"
        }
      ]
    },
