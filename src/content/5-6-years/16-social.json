  "id": "social_102",
  "name": "社交技能",
  "ageRange": "5-6",
  "domain": "social",
  "duration": 10,
  "difficulty": 1,
  "objectives": [
    "学会基本的社交礼貌用语",
    "掌握与人友好相处的方法",
    "培养分享和合作的意识"
  ],
  "content": [
    {
      "type": "lesson",
      "title": "朋友你好",
      "text": "和朋友一起玩真开心！让我们来学习怎么做朋友：\n\n🤝 打招呼：\n- 你好！早上好！\n- 点头、挥手、微笑\n\n🙏 谢谢和对不起：\n- 别人帮助你要说谢谢\n- 做了错事要说对不起\n\n👫 一起玩：\n- 轮流玩，不抢玩具\n- 分享自己的玩具\n- 尊重朋友的玩法",
      "examples": [
        {
          "打招呼": "你好！/ Hello！/ 早上好！"
        },
        {
          "感谢": "谢谢！/ 感谢你！/ 太好了！"
        },
        {
          "道歉": "对不起！/ 抱歉！/ 我错了！"
        }
      ]
    },
    {
      "type": "game",
      "title": "社交小达人",
      "description": "遇到这种情况该怎么说？",
      "questions": [
        {
          "q": "小明帮你捡起了玩具，你该说什么？",
          "options": [
            "谢谢",
            "没关系",
            "去去去"
          ],
          "answer": "谢谢"
        },
        {
          "q": "你不小心撞到了朋友，该说什么？",
          "options": [
            "对不起",
            "活该",
            "走开"
          ],
          "answer": "对不起"
        },
        {
          "q": "看到新朋友，该怎么打招呼？",
          "options": [
            "你好",
            "走开",
            "给我玩"
          ],
          "answer": "你好"
        },
        {
          "q": "朋友想玩你的玩具，该怎么做？",
          "options": [
            "轮流玩",
            "不给",
            "抢回来"
          ],
          "answer": "轮流玩"
        }
      ]
    },
    {
      "type": "practice",
      "title": "情景演练",
      "description": "练习社交场景",
      "scenarios": [
        {
          "场景": "见到新朋友",
          "台词": "你好，我叫XXX，很高兴认识你！"
        },
        {
          "场景": "请求加入游戏",
          "台词": "我可以和你们一起玩吗？"
        },
        {
          "场景": "得到帮助",
          "台词": "谢谢你帮助我！"
        }
      ]
    }
  ],
