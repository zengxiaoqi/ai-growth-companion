# ========================================
# 生产环境部署配置
# ========================================
# 复制为 .env 并填入真实值：
#   cp .env.example .env

# ---- GitHub Container Registry ----
# 用于拉取 Docker 镜像
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_ACTOR=your_github_username

# ---- Backend ----
JWT_SECRET=your-super-secret-jwt-key-change-me
OPENAI_API_KEY=your_openai_api_key
DASHSCOPE_API_KEY=your_dashscope_api_key

# ---- Server ----
DEPLOY_HOST=your.server.ip
DEPLOY_USER=root
DEPLOY_PORT=22
DEPLOY_PATH=/opt/lingxi-companion

# ---- Docker Images (可选，覆盖默认) ----
# BACKEND_IMAGE=ghcr.io/zengxiaoqi/ai-growth-companion/backend:latest
# FRONTEND_IMAGE=ghcr.io/zengxiaoqi/ai-growth-companion/frontend:latest
