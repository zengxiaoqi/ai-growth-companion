{
  "id": "art_101",
  "name": "创意绘画",
  "ageRange": "5-6",
  "domain": "art",
  "duration": 15,
  "difficulty": 1,
  "objectives": [
    "掌握基本的绘画姿势",
    "能够画出简单的形状和物品",
    "发挥想象力进行创作"
  ],
  "content": [
    {
      "type": "lesson",
      "title": "小小画家",
      "text": "绘画是一件很有趣的事情！\n\n🖌️ 握笔姿势：拇指和食指捏住笔，像夹东西一样，中指放在下面支撑。\n\n🎨 基本图形：\n- 圆形：画圆圈，像太阳\n- 方形：画四个边，像桌子\n- 三角形：画三条线，像屋顶\n\n🌈 颜色认识：红、橙、黄、绿、蓝、紫\n\n让我们开始画画吧！",
      "examples": [
        {"画太阳": "先画一个大圆圈，再画几条线"},
        {"画小花": "中间画一个圆，周围画几片花瓣"},
        {"画小树": "先画一个三角形，再画一个长方形"}
      ]
    },
    {
      "type": "game",
      "title": "画一画",
      "description": "跟着步骤画",
      "tasks": [
        {"主题": "苹果", "步骤": ["画一个圆形", "画一个果柄"]},
        {"主题": "小船", "步骤": ["画一个半圆形", "画一个帆"]},
        {"主题": "房子", "步骤": ["画一个正方形", "画一个三角形屋顶", "画一个门"]}
      ]
    },
    {
      "type": "practice",
      "title": "自由创作",
      "description": "画你想画的东西",
      "prompts": [
        "画一个你喜欢的动物",
        "画一个你的家人",
        "画一个美丽的花园"
      ]
    }
  ],
  "media": {
    "images": ["/assets/images/art/drawing.png"]
  },
  "abilities": {
    "creativity": 25,
    "fineMotor": 15
  }
}